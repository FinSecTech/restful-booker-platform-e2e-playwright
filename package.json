{
  "name": "qa_automationintesting.online",
  "version": "1.0.0",
  "description": "Automation in Testing Platform (E2E + API)",
  "main": "index.js",
  "scripts": {
    "test": "dotenvx run -f .env.production -- playwright test",
    "test:smoke": "dotenvx run -f .env.production -- playwright test --grep @smoke",
    "test:sanity": "dotenvx run -f .env.production -- playwright test --grep @sanity",
    "test:regression": "dotenvx run -f .env.production -- playwright test --grep @regression",
    "test:api": "dotenvx run -f .env.production -- playwright test --grep @api",
    "test:visual": "dotenvx run -f .env.production -- playwright test --grep @visual",
    "allure:generate": "node ./node_modules/allure-commandline/bin/allure generate allure-results --clean -o allure-report",
    "allure:open": "node ./node_modules/allure-commandline/bin/allure open allure-report",
    "allure:history:prepare": "mkdir -p allure-results/history"
  },
  "keywords": [],
  "author": "Eugene Popov",
  "license": "CC BY-NC",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.68.1",
    "allure": "^3.8.2",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0"
  }
}
